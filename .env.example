# Convex (https://dashboard.convex.dev)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk (https://dashboard.clerk.com)
# Client-side publishable key (Vite exposes VITE_* vars)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Server-side Clerk secret (never expose to the browser)
CLERK_SECRET_KEY=sk_test_...

# Convex auth: Clerk JWT issuer domain from Clerk Dashboard → JWT Templates
# Create a JWT template named "convex" and set this to the Issuer URL.
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-subdomain.clerk.accounts.dev

# Optional Clerk route URLs for sign-in/up flows (UI subagent)
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
